<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ 战区代理"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#E94560"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本地 VPN 代理 · 流量劫持"
            android:textSize="13sp"
            android:textColor="#888899"
            android:layout_marginBottom="32dp" />

        <!-- 省份选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="省份 / 直辖市"
            android:textSize="12sp"
            android:textColor="#667788"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_province"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="#16213E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- 城市选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="城市"
            android:textSize="12sp"
            android:textColor="#667788"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_city"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="#16213E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:enabled="false" />

        <!-- 区县选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="区县"
            android:textSize="12sp"
            android:textColor="#667788"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_district"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="#16213E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:enabled="false" />

        <!-- 状态卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16213E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="连接状态"
                android:textSize="11sp"
                android:textColor="#556677"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未连接"
                android:textSize="15sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="代理信息"
                android:textSize="11sp"
                android:textColor="#556677"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_traffic_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#4FC3F7" />
        </LinearLayout>

        <!-- 开始/断开按钮 -->
        <Button
            android:id="@+id/btn_start_vpn"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="开始修改"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp" />

        <!-- 功能说明 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#16213E"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="注入请求头"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#E94560"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X-Adcode: {区划代码}"
                android:textSize="12sp"
                android:textColor="#888899"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X-Region: {完整地区名}"
                android:textSize="12sp"
                android:textColor="#888899"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X-Location-Code: {区划代码}"
                android:textSize="12sp"
                android:textColor="#888899"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X-Forwarded-Region: {完整地区名}"
                android:textSize="12sp"
                android:textColor="#888899"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
